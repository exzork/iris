# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# MCP (Model Context Protocol) Configuration
# IRIS_OWNER_ID: Discord user ID authorized to add/remove MCP servers via Iris.
# Only this user's messages can trigger mcp_add / mcp_remove / mcp_list tool calls.
# Leave unset to disable runtime MCP mutation entirely (file-based config only).
IRIS_OWNER_ID=
# MCP_CONFIG_PATH: path to mcps.json. Defaults to "mcps.json" relative to the
# process working directory. In docker this resolves to /app/mcps.json.
MCP_CONFIG_PATH=

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=postgres://iris_user:iris_password@postgres:5432/iris
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=iris_user
POSTGRES_PASSWORD=iris_password
POSTGRES_DB=iris

# LLM Model Configuration
LLM_MODEL=gpt-4
LLM_BASE_URL=https://api.openai.com
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# LLM_TIMEOUT: legacy fallback timeout for all LLM calls (default: 2m)
# Prefer LLM_CHAT_TIMEOUT and LLM_TOOL_TIMEOUT for granular control
LLM_TIMEOUT=2m
# LLM_CHAT_TIMEOUT: timeout for plain chat/reply calls (default: 2m)
# Falls back to LLM_TIMEOUT if not set
LLM_CHAT_TIMEOUT=2m
# LLM_TOOL_TIMEOUT: timeout for tool-call streaming completions (default: 10m)
# Falls back to LLM_TIMEOUT * 4 (rounded up to minute) if not set
LLM_TOOL_TIMEOUT=10m
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1s

# Classifier model (fast, picks default vs strong tier)
LLM_MODEL_ROUTER=kr/claude-haiku-4.5
# Standard reply model
LLM_MODEL_DEFAULT=kr/claude-haiku-4.5
# Heavy-reasoning model for complex lore / debugging / long analysis
LLM_MODEL_STRONG=kr/claude-opus-4.7

# Owner runtime model switching
#
# When IRIS_OWNER_ID is set, three additional owner-gated tools are
# registered: iris_set_model, iris_reset_model, iris_get_models. The owner
# can ask Iris in natural language (e.g. "switch default model to
# kr/claude-sonnet-4.5") and the change is persisted to global_settings,
# surviving restarts. The LLM_MODEL_* values above act as fallbacks used
# when no override is stored.

# Debug mode: enables LLM audit logging with duration_ms and context metadata
# Set to "true" or "1" to enable; default is false
DEBUG=false

# Conversation lock TTL: duration for which a conversation remains active after bot reply
# Accepts Go duration strings (e.g., "5m", "30s", "2m30s")
# During this window, subsequent messages are checked for relevance to keep conversation alive
# Default: 5m
IRIS_CONV_LOCK_TTL=5m

# Migration fallback for allowed channels: if true, uses exception list as fallback
# when no allowed channels are configured (default true for backward compatibility)
ALLOWED_CHANNELS_MIGRATION_FALLBACK=true

# Embedding-based context classifier. When both paths are set, Iris uses
# sentence-transformers/paraphrase-MiniLM-L3-v2 (384-dim) via ONNX for in-window
# relevance and cross-channel classification. When unset, falls back to LLM.
IRIS_EMBED_MODEL_PATH=/opt/iris-models/paraphrase-MiniLM-L3-v2/model.onnx
IRIS_EMBED_TOKENIZER_PATH=/opt/iris-models/paraphrase-MiniLM-L3-v2/tokenizer.json
IRIS_EMBED_SIM_THRESHOLD=0.55

# Web search provider for the LLM tool-call pipeline.
# Prefer IRIS_SEARXNG_URL when running with docker-compose (local SearXNG instance).
# Leave blank to disable; Iris will not invoke web search until one is set.
IRIS_SEARXNG_URL=http://searxng:8080
# Fallback: external HTTP search provider (e.g., Brave Search API)
SEARCH_BASE_URL=
SEARCH_API_KEY=

# Lore Thread Protocol Configuration
# Enable/disable the lore thread worker (default: false)
IRIS_LORE_THREADS_ENABLED=false
# Idle duration before a lore thread is considered stale (default: 24h)
IRIS_LORE_IDLE_DURATION=24h
# Target size for lore compaction in tokens (default: 50000)
IRIS_LORE_COMPACTION_TARGET=50000
# Max threads created per hour per guild (default: 10)
IRIS_LORE_THREAD_CAP_PER_HOUR=10
# Worker poll interval for checking stale threads (default: 5m)
IRIS_LORE_WORKER_POLL_INTERVAL=5m
# LLM timeout for lore operations (default: 30s, set to 0 for no deadline)
IRIS_LORE_LLM_TIMEOUT=30s
# LLM model for lore operations (classifier, summarizer, title generator)
# When unset, falls back to LLM_MODEL_STRONG
IRIS_LORE_LLM_MODEL=
# Per-message lore classification deadline (default: 60s, set to 0 for no deadline)
# Lore LLM model can be slow — set 0 if using opus-class models
IRIS_LORE_CAPTURE_TIMEOUT=60s
