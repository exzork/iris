{
  "mcpServers": {
    "_comment": "Claude Desktop-compatible mcps.json. Each entry spawns an MCP server subprocess at startup. Tools are exposed to Iris as '<server>_<tool>'. Missing/unstartable servers are logged and skipped.",
    "_example_filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/data"],
      "env": {}
    },
    "_example_github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_yourTokenHere"
      }
    }
  }
}
